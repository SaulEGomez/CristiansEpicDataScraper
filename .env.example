# ==========================================
# LEAD GEN PIPELINE - LOCAL SETTINGS
# Rename this file to .env and add your keys
# ==========================================

# Salesforce Credentials
SF_USERNAME="your.name@company.com"
SF_PASSWORD="your_salesforce_password"
SF_SECURITY_TOKEN="your_salesforce_security_token"
SF_DOMAIN="login" # Change to 'test' if using a Salesforce Sandbox

# Pipeline Behavior Preferences
TARGET_REGION="California"
MAX_LEADS_PER_RUN=100

# Optional: API Keys (If you ever add paid/freemium services later)
# GOOGLE_CUSTOM_SEARCH_API_KEY="your_api_key_here"
